# Copy this file to .env and fill in your key to enable smart mode.
# Without a key, Jarvis still handles basic commands (open apps, websites, time, etc.)

ANTHROPIC_API_KEY=

# Optional overrides
JARVIS_MODEL=claude-haiku-4-5-20251001
JARVIS_USER=Sir

# --- LEGO rover (optional) ---
# Leave ROBOT_HUB_MAC blank to connect by name; fill it in for a faster,
# more reliable connection (find it by running calibrate_ports.py once
# with a Bluetooth scanner, or via Windows' Bluetooth device list).
ROBOT_HUB_NAME=LEGO Move Hub
ROBOT_HUB_MAC=
# Which external port (C or D) the claw motor and head motor are plugged
# into — run calibrate_ports.py to figure this out and fill these in.
ROBOT_CLAW_PORT=D
ROBOT_HEAD_PORT=C
ROBOT_DRIVE_SPEED=0.6
ROBOT_DRIVE_SECONDS=1.5
ROBOT_TURN_SECONDS=0.8
# Flip these to true if a tread spins backward when it should go forward
# (run calibrate_ports.py to determine this automatically).
ROBOT_LEFT_INVERT=false
ROBOT_RIGHT_INVERT=false
